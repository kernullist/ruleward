{
  "name": "ruleward",
  "version": "0.0.0",
  "description": "Lint AI agent rule files (AGENTS.md, CLAUDE.md, Cursor rules) for conflicts, duplication, bloat, and drift from your code.",
  "type": "module",
  "bin": {
    "ruleward": "src/cli.ts"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx src/cli.ts",
    "bench": "tsx src/bench/main.ts",
    "bench:nli": "tsx src/bench/nli-eval.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "optionalDependencies": {
    "@xenova/transformers": "^2.17.2"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "gpt-tokenizer": "^2.9.0",
    "gray-matter": "^4.0.3",
    "mdast-util-to-string": "^4.0.0",
    "remark-parse": "^11.0.0",
    "tinyglobby": "^0.2.10",
    "tree-sitter-wasms": "^0.1.13",
    "unified": "^11.0.5",
    "web-tree-sitter": "^0.22.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
